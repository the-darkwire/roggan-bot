{
  "name": "roggan-bot",
  "version": "1.1.0",
  "description": "Discord bot for playing AoE2 taunts",
  "main": "index.js",
  "scripts": {
    "dev": "tsx index.ts",
    "start": "tsx index.ts",
    "deploy-commands": "tsx src/deploy-commands.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "Tyler Coleman",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-darkwire/roggan-bot.git"
  },
  "bugs": {
    "url": "https://github.com/the-darkwire/roggan-bot/issues"
  },
  "homepage": "https://github.com/the-darkwire/roggan-bot#readme",
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "ffmpeg-static": "^5.3.0",
    "libsodium-wrappers": "^0.8.4",
    "tsx": "^4.22.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@11.3.0"
}
